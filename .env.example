VITE_SUPABASE_URL=your-project-url-here
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Optional: Geoapify autocomplete for job site street (https://www.geoapify.com/)
VITE_GEOAPIFY_API_KEY=

# ── Server-only (read by server/app-server.mjs at runtime — not VITE_) ─────────
# Loaded from .env then .env.local (local overrides). Same keys in production.

# Optional: Sentry DSN for server-side error tracking (uncaught errors + unhandled request failures)
# SENTRY_DSN=

# DocuSeal work order e-sign (HTML submissions + webhooks)
# DOCUSEAL_API_KEY=
# DOCUSEAL_BASE_URL=https://api.docuseal.com
# Exact header name + secret from DocuSeal webhook settings (do not invent the name)
# DOCUSEAL_WEBHOOK_HEADER_NAME=
# DOCUSEAL_WEBHOOK_HEADER_VALUE=

# Service role: server updates jobs.esign_* after DocuSeal calls and on webhooks (RLS bypass; routes verify job ownership)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Stripe payment processing / Connect onboarding (optional)
# Public app origin used for Stripe Connect return/refresh redirects
# APP_BASE_URL=https://your-app.example.com
# Client-side publishable key (prefixed with VITE_) - reserved for future client Stripe surfaces
# VITE_STRIPE_PUBLISHABLE_KEY=
# Server-side secret key (not VITE_)
# STRIPE_SECRET_KEY=
# Server-side webhook secret for payment reconciliation
# STRIPE_WEBHOOK_SECRET=

# Resend email delivery for invoice PDF attachments
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@ironwork.app

# Optional: Umami analytics (https://umami.is/) — injected in index.html at build time
# VITE_UMAMI_WEBSITE_ID=
