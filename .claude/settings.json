{
  "permissions": {
    "allow": [
      "Bash(git -C /home/billy/Documents/MVPs/scope-lock diff HEAD src/components/WorkOrdersPage.tsx)",
      "Bash(git -C /home/billy/Documents/MVPs/scope-lock stash list)",
      "Bash(git -C /home/billy/Documents/MVPs/scope-lock show HEAD:src/components/WorkOrdersPage.tsx)",
      "Bash(git -C /home/billy/Documents/MVPs/scope-lock add src/components/WorkOrderDetailPage.tsx)",
      "Bash(git -C /home/billy/Documents/MVPs/scope-lock commit -m ' *)",
      "Bash(git -C /home/billy/Documents/MVPs/scope-lock diff -- .claude/settings.json)",
      "Bash(git -C /home/billy/Documents/MVPs/scope-lock log --oneline -3)",
      "Bash(git -C /home/billy/Documents/MVPs/scope-lock add .claude/settings.json)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); if [ -z \"$f\" ]; then exit 0; fi; case \"$f\" in *.ts|*.tsx|*.js|*.mjs|*.jsx) npx eslint --no-warn-on-unmatched-pattern --max-warnings 0 \"$f\" 2>&1 | tail -10; exit 0 ;; *) exit 0 ;; esac",
            "timeout": 30,
            "statusMessage": "Linting..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-css-colocation.sh",
            "timeout": 15,
            "statusMessage": "Checking CSS co-location..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-html-escape.sh",
            "timeout": 15,
            "statusMessage": "Checking esc() usage..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/log-commands.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-dangerous.sh",
            "timeout": 10,
            "statusMessage": "Checking command safety..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/protect-files.sh",
            "timeout": 10,
            "statusMessage": "Checking file protection..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/living-docs-reminder.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
